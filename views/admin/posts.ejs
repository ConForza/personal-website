<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Blog Posts</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <main class="main-container">
      <nav class="admin-nav">
        <a href="/admin">Dashboard</a>
        <a href="/admin/posts">Manage Posts</a>
        <a href="/admin/posts/new">Create Post</a>
        <a href="/">View Site</a>
        <form action="/admin/logout" method="POST" style="display: inline">
          <button type="submit">Logout</button>
        </form>
      </nav>
      <h1>Manage Blog Posts</h1>

      <% if (flashMessage) { %>
        <p style="color: green;"><%= flashMessage %></p>
      <% } %>

      <% if (!posts || posts.length === 0) { %>
        <p>No blog posts found.</p>
      <% } else { %>
        <ul>
          <% posts.forEach(post => { %>
            <li>
              <h2><%= post.title %></h2>

              <% if (post.date) { %>
                <p>Date: <%= post.date %></p>
              <% } %>

              <p>
                Status:
                <% if (post.archived) { %>
                  Archived
                <% } else { %>
                  Live
                <% } %>
              </p>

              <p>
                <a href="/posts/<%= post._id %>">View public post</a>
              </p>

              <p>
                <a href="/admin/posts/<%= post._id %>/edit">Edit post</a>
              </p>

              <form method="POST" action="/admin/posts/<%= post._id %>/archive" onsubmit="return confirm('Are you sure you want to <% if (post.archived) { %>unarchive<% } else { %>archive<% } %> this post?');">
                <button type="submit">
                  <% if (post.archived) { %>
                    Unarchive post
                  <% } else { %>
                    Archive post
                  <% } %>
                </button>
              </form>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </main>
  </body>
</html>