<!-- Import header -->
<%- include("partials/header.ejs") %>
<body>
  <div class="contact-frame">
  <form class="contact-text" action="/contact" method="POST">
    <% if (locals.error) { %>
      <p class="error-message"><%= error %></p>
    <% } %>

    <% if (locals.successMessage) { %>
      <p class="success-message"><%= successMessage %></p>
    <% } %>

    <h2>Contact Me</h2>
    <div>
      <label for="name">Name</label>
      <input id="name" type="text" name="name" value="<%= locals.formData?.name || '' %>" required>
    </div>
    <div>
      <label for="email">Email</label>
      <input id="email" type="email" name="email" value="<%= locals.formData?.email || '' %>" required>
    </div>
    <div>
      <label for="message">Message</label>
      <textarea id="message" name="message" rows="8" required><%= locals.formData?.message || '' %></textarea>
    </div>

    <div class="hidden-field">
      <label for="website">Website</label>
      <input id="website" name="website" type="text" autocomplete="off" tabindex="-1">
    </div>

    <button type="submit">Send Message</button>
  </form>
  </div>
</body>
<!-- Import footer -->
<%- include("partials/footer.ejs") %>
